{
  "description": "Language filter: indexing only books in English",
  "library": [
    { "title": "Russian Book", "authors": ["Author,One,"], "lang": "ru" },
    { "title": "English Book", "authors": ["Author,Two,"], "lang": "en" }
  ],
  "config": {
    "filters": { "includeLanguages": ["en"] }
  },
  "steps": [
    { "args": ["import"] },
    { "args": ["query", "--limit", "10"] }
  ],
  "expected": {
    "totalFound": 1,
    "books": [ { "title": "English Book" } ]
  }
}
